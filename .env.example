# 环境变量配置示例 / Environment variables example
# 复制此文件为 .env 并填写您的配置 / Copy this file to .env and fill in your configuration

# OpenAI API 密钥（必填）/ OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# API 基础地址（可选，用于兼容 OpenAI 格式的其他 API）
# API Base URL (optional, for other OpenAI-compatible APIs)
OPENAI_BASE_URL=https://api.openai.com/v1

# 使用的语言模型 / Language model to use
MODEL_NAME=gpt-3.5-turbo

# 嵌入模型 / Embedding model
EMBEDDING_MODEL=text-embedding-ada-002

# 向量数据库存储路径 / Vector store path
VECTOR_STORE_PATH=./vector_store

# 知识库数据路径 / Knowledge base data path
KNOWLEDGE_BASE_PATH=./knowledge/data

# 服务器配置 / Server configuration
HOST=0.0.0.0
PORT=8000

# Agent 配置 / Agent configuration
MAX_ITERATIONS=5
TEMPERATURE=0.2
MAX_TOKENS=2048
